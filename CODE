# =====================================
# 공격 / 수비
# =====================================

attack = 0
defender = 0

for match in matches:

    if match["better_rounds"] == "attacker":
        attack += 1

    elif match["better_rounds"] == "defender":
        defender += 1

print(f"공격이 더 좋았던 경기 : {attack}/{games} ({attack/games*100:.1f}%)")
print(f"수비가 더 좋았던 경기 : {defender}/{games} ({defender/games*100:.1f}%)")
print()

# =====================================
# Over Kill / Over Death
# =====================================

over_kill = 0
over_death = 0
same = 0

for match in matches:

    if match["kills"] > match["deaths"]:
        over_kill += 1

    elif match["kills"] < match["deaths"]:
        over_death += 1

    else:
        same += 1

print(f"Over Kill : {over_kill}/{games} ({over_kill/games*100:.1f}%)")
print(f"Over Death : {over_death}/{games} ({over_death/games*100:.1f}%)")
print(f"Same K/D : {same}/{games} ({same/games*100:.1f}%)")
print()

# =====================================
# 평균 ACS
# =====================================

total_acs = 0

for match in matches:
    total_acs += match["acs"]

average_acs = total_acs / games

print(f"평균 ACS : {average_acs:.1f}")

if average_acs >= 240:
    grade = "매우 훌륭함"
elif average_acs >= 200:
    grade = "좋음"
elif average_acs >= 170:
    grade = "평균"
elif average_acs >= 140:
    grade = "아쉬움"
else:
    grade = "나쁨"

print(f"ACS 등급 : {grade}")
print()

