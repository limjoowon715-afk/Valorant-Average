# =====================================
# 요원별 승률 + 평균 ACS
# =====================================

agent_stats = {}

for match in matches:

    agent = match["agent"]

    if agent not in agent_stats:
        agent_stats[agent] = {
            "games":0,
            "wins":0,
            "total_acs":0
        }

    agent_stats[agent]["games"] += 1
    agent_stats[agent]["total_acs"] += match["acs"]

    if match["result"] == "win":
        agent_stats[agent]["wins"] += 1

print("=" * 50)
print("요원별 분석")
print("=" * 50)

for agent in agent_stats:

    games_played = agent_stats[agent]["games"]
    wins = agent_stats[agent]["wins"]

    win_rate = wins / games_played * 100
    average_acs = agent_stats[agent]["total_acs"] / games_played

    print(f"{agent}")
    print(f"   경기 수 : {games_played}")
    print(f"   승률 : {win_rate:.1f}%")
    print(f"   평균 ACS : {average_acs:.1f}")
    print()

# =====================================
# 맵별 승률
# =====================================

map_stats = {}

for match in matches:

    map_name = match["map"]

    if map_name not in map_stats:
        map_stats[map_name] = {
            "games":0,
            "wins":0
        }

    map_stats[map_name]["games"] += 1

    if match["result"] == "win":
        map_stats[map_name]["wins"] += 1

print("=" * 50)
print("맵별 승률")
print("=" * 50)

for map_name in map_stats:

    games_played = map_stats[map_name]["games"]
    wins = map_stats[map_name]["wins"]

    rate = wins / games_played * 100

    print(f"{map_name} : {wins}/{games_played} ({rate:.1f}%)")

print()

